# ===========================================================================
# Financial Agent — Plantilla de variables de entorno
# Copia este fichero a .env y rellena tus valores reales.
#   cp .env.example .env
# El fichero .env está excluido en .gitignore — nunca se commitea.
# ===========================================================================

# --- Capa IA (LiteLLM) ---
# Cambiar de modelo = modificar SOLO esta línea (cero cambios de código).
# Nota: el antiguo groq/llama3-8b-8192 fue descatalogado por Groq.
AI_MODEL=groq/llama-3.1-8b-instant
GROQ_API_KEY=gsk_tu_api_key_aqui

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=123456789:AAH_tu_token_aqui
TELEGRAM_CHAT_ID=325873849

# --- Gmail API (OAuth) ---
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=data/gmail_token.json

# --- Base de datos ---
DATABASE_URL=sqlite:///data/financial_agent.db
